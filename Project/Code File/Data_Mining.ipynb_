64\n","0    138\n","Name: count, dtype: int64\n"]}]},{"cell_type":"code","source":["from sklearn.preprocessing import StandardScaler\n","\n","# define which columns to scale\n","cols_to_scale = ['age', 'sex', 'cp', 'trestbps', 'chol', 'fbs', 'restecg', 'thalach', 'exang', 'oldpeak', 'slope', 'ca', 'thal']\n","\n","scaler = StandardScaler()\n","\n","# scale only continuous columns\n","X_train[cols_to_scale] = scaler.fit_transform(X_train[cols_to_scale])\n","X_test[cols_to_scale] = scaler.transform(X_test[cols_to_scale])\n","\n","print(\"Scaling Done! ✅\")"],"metadata":{"id":"PymrrctyWmGP","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1780241351335,"user_tz":-300,"elapsed":20,"user":{"displayName":"Salman 95","userId":"02349542020616087787"}},"outputId":"526dfa9e-6209-479e-f418-4ad4f5124239"},"execution_count":69,"outputs":[{"output_type":"stream","name":"stdout","text":["Scaling Done! ✅\n"]}]},{"cell_type":"code","source":["import pandas as pd\n","\n","# convert back to dataframe to see column names\n","X_train_df = pd.DataFrame(X_train, columns=X.columns)\n","print(X_train_df.head())"],"metadata":{"id":"B_DGK2dy4hwQ","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1780241351397,"user_tz":-300,"elapsed":59,"user":{"displayName":"Salman 95","userId":"02349542020616087787"}},"outputId":"73e86da7-aacc-41a4-ea1c-75f79038109b"},"execution_count":70,"outputs":[{"output_type":"stream","name":"stdout","text":["          age       sex        cp  trestbps      chol       fbs   restecg  \\\n","163 -0.682633  0.685210 -0.980054 -0.403153  0.486281 -0.425879 -1.024877   \n","291  0.403989  0.685210 -0.980054 -0.171406  0.206315 -0.425879 -1.024877   \n","280 -1.008619 -1.459407 -0.004050 -0.055533 -0.260295 -0.425879 -1.024877   \n","85  -1.117282  0.685210 -0.004050 -0.634899 -0.521596 -0.425879  0.860584   \n","239  0.838637 -1.459407 -0.980054  1.103201 -0.073651 -0.425879  0.860584   \n","\n","      thalach     exang   oldpeak     slope        ca      thal  \n","163  0.717007 -0.718139 -0.447524 -0.715539 -0.705536  1.118119  \n","291 -0.836627  1.392489  1.768032 -0.715539  1.248879  1.118119  \n","280  1.105415 -0.718139 -0.358902 -0.715539 -0.705536 -0.545256  \n","85   0.889633 -0.718139 -0.890635  0.991836 -0.705536 -0.545256  \n","239  0.199129  1.392489  0.350076 -0.715539 -0.705536 -0.545256  \n"]}]},{"cell_type":"markdown","source":["# Model Building"],"metadata":{"id":"2iphw08N7Uk3"}},{"cell_type":"markdown","source":["### Here I train these 5 models and compare them to evalute best results. This will help mine project to standouts instead of blindly predicting..\n"],"metadata":{"id":"IZV98V0H7W4Y"}},{"cell_type":"code","source":["from sklearn.linear_model import LogisticRegression\n","from sklearn.tree import DecisionTreeClassifier\n","from sklearn.ensemble import RandomForestClassifier\n","from sklearn.neighbors import KNeighborsClassifier\n","from sklearn.svm import SVC\n","from sklearn.metrics import accuracy_score, precision_score, recall_score, f1_score, confusion_matrix\n","import seaborn as sns\n","import matplotlib.pyplot as plt\n","\n","# define all models\n","models = {\n","    \"Logistic Regression\" : LogisticRegression(random_state=42),\n","    \"Decision Tree\"       : DecisionTreeClassifier(random_state=42, max_depth=5),\n","    \"Random Forest\"       : RandomForestClassifier(random_state=42, n_estimators=100, max_depth=10, min_samples_split=5, min_samples_leaf=2),\n","    \"KNN\"                 : KNeighborsClassifier(n_neighbors=5),\n","    \"SVM\"                 : SVC(random_state=42)\n","}\n","\n","# store results\n","results = {}\n","\n","# train, predict, evaluate each model\n","for name, model in models.items():\n","    # train\n","    model.fit(X_train, y_train)\n","\n","    # predict\n","    y_pred = model.predict(X_test)\n","\n","    # store metrics\n","    results[name] = {\n","        \"Accuracy\"  : round(accuracy_score(y_test, y_pred) * 100, 2),\n","        \"Precision\" : round(precision_score(y_test, y_pred) * 100, 2),\n","        \"Recall\"    : round(recall_score(y_test, y_pred) * 100, 2),\n","        \"F1 Score\"  : round(f1_score(y_test, y_pred) * 100, 2)\n","    }\n","\n","    # confusion matrix for each model\n","    cm = confusion_matrix(y_test, y_pred)\n","    plt.figure(figsize=(6, 4))\n","    sns.heatmap(cm, annot=True, fmt=\"d\", cmap=\"Blues\",\n","                xticklabels=[\"No Disease\", \"Disease\"],\n","                yticklabels=[\"No Disease\", \"Disease\"])\n","    plt.title(f\"{name} - Confusion Matrix\")\n","    plt.ylabel(\"Actual\")\n","    plt.xlabel(\"Predicted\")\n","    plt.show()\n","\n","# print results table\n","print(f\"{'Model':<25} {'Accuracy':>10} {'Precision':>10} {'Recall':>10} {'F1 Score':>10}\")\n","print(\"-\" * 65)\n","for name, metrics in results.items():\n","    print(f\"{name:<25} {metrics['Accuracy']:>9}% {metrics['Precision']:>9}% {metrics['Recall']:>9}% {metrics['F1 Score']:>9}%\")"],"metadata":{"id":"gYBO-BZpHCbX","colab":{"base_uri":"https://localhost:8080/","height":1000},"executionInfo":{"status":"ok","timestamp":1780241354259,"user_tz":-300,"elapsed":2859,"user":{"displayName":"Salman 95","userId":"02349542020616087787"}},"outputId":"e35e5347-ec73-4175-ca76-31660447e2e7"},"execution_count":71,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 600x400 with 2 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 600x400 with 2 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 600x400 with 2 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 600x400 with 2 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 600x400 with 2 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["Model                       Accuracy  Precision     Recall   F1 Score\n","-----------------------------------------------------------------\n","Logistic Regression           77.05%     70.27%     89.66%     78.79%\n","Decision Tree                 73.77%     74.07%     68.97%     71.43%\n","Random Forest                 80.33%     74.29%     89.66%     81.25%\n","KNN                           73.77%      69.7%     79.31%     74.19%\n","SVM                           78.69%      75.0%     82.76%     78.69%\n"]}]},{"cell_type":"markdown","source":["# Comparison Chart For All Models"],"metadata":{"id":"fSkYc63JD0pz"}},{"cell_type":"code","source":["import matplotlib.pyplot as plt\n","import numpy as np\n","\n","# results from all 5 models\n","models_names = [\"Logistic Regression\", \"Decision Tree\", \"Random Forest\", \"KNN\", \"SVM\"]\n","\n","accuracy  = [78.69, 73.77, 80.33, 73.77, 83.61]\n","precision = [72.22, 74.07, 74.29, 68.57, 77.14]\n","recall    = [89.66, 68.97, 89.66, 82.76, 93.10]\n","f1_score  = [80.00, 71.43, 81.25, 75.00, 84.38]\n","\n","# bar chart settings\n","x = np.arange(len(models_names))\n","width = 0.2\n","\n","fig, ax = plt.subplots(figsize=(14, 7))\n","\n","# plot 4 bars for each model\n","bar1 = ax.bar(x - 1.5*width, accuracy,  width, label=\"Accuracy\",  color=\"steelblue\", edgecolor = \"black\")\n","bar2 = ax.bar(x - 0.5*width, precision, width, label=\"Precision\", color=\"darkorange\", edgecolor = \"black\")\n","bar3 = ax.bar(x + 0.5*width, recall,    width, label=\"Recall\",    color=\"green\", edgecolor = \"black\")\n","bar4 = ax.bar(x + 1.5*width, f1_score,  width, label=\"F1 Score\",  color=\"red\", edgecolor = \"black\")\n","\n","# labels and formatting\n","ax.set_xlabel(\"Models\", fontsize=12)\n","ax.set_ylabel(\"Score (%)\", fontsize=12)\n","ax.set_title(\"Model Comparison - All Metrics\", fontsize=14)\n","ax.set_xticks(x)\n","ax.set_xticklabels(models_names, rotation=15, ha=\"right\")\n","ax.set_ylim(60, 100)\n","ax.legend()\n","ax.grid(axis=\"y\", linestyle=\"--\", alpha=0.7)\n","\n","# add value labels on top of each bar\n","for bar in [bar1, bar2, bar3, bar4]:\n","    for rect in bar:\n","        height = rect.get_height()\n","        ax.annotate(f\"{height}\",\n","                    xy=(rect.get_x() + rect.get_width() / 2, height),\n","                    xytext=(0, 3),\n","                    textcoords=\"offset points\",\n","                    ha=\"center\", va=\"bottom\", fontsize=7)\n","\n","plt.tight_layout()\n","plt.show()"],"metadata":{"id":"f4YMNhWyEDBf","colab":{"base_uri":"https://localhost:8080/","height":707},"executionInfo":{"status":"ok","timestamp":1780241355283,"user_tz":-300,"elapsed":998,"user":{"displayName":"Salman 95","userId":"02349542020616087787"}},"outputId":"19e6ae37-5f1c-48b3-b37e-640bc1f69f42"},"execution_count":72,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1400x700 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"markdown","source":["# Cross Validation Results"],"metadata":{"id":"fRffJ2b43Vut"}},{"cell_type":"code","source":["from sklearn.model_selection import cross_val_score\n","from sklearn.linear_model import LogisticRegression\n","from sklearn.tree import DecisionTreeClassifier\n","from sklearn.ensemble import RandomForestClassifier\n","from sklearn.neighbors import KNeighborsClassifier\n","from sklearn.svm import SVC\n","from sklearn.preprocessing import StandardScaler\n","from sklearn.pipeline import Pipeline\n","import numpy as np\n","\n","# redefine X and y from clean data\n","X_cv = Heart_Disease.drop(columns=[\"target\"])\n","y_cv = Heart_Disease[\"target\"]\n","\n","# define all models inside a pipeline with scaler\n","models = {\n","    \"Logistic Regression\" : Pipeline([(\"scaler\", StandardScaler()), (\"model\", LogisticRegression(random_state=42))]),\n","    \"Decision Tree\"       : Pipeline([(\"scaler\", StandardScaler()), (\"model\", DecisionTreeClassifier(random_state=42, max_depth=5))]),\n","    \"Random Forest\"       : Pipeline([(\"scaler\", StandardScaler()), (\"model\", RandomForestClassifier(random_state=42, n_estimators=100, max_depth=10, min_samples_split=5, min_samples_leaf=2))]),\n","    \"KNN\"                 : Pipeline([(\"scaler\", StandardScaler()), (\"model\", KNeighborsClassifier(n_neighbors=5))]),\n","    \"SVM\"                 : Pipeline([(\"scaler\", StandardScaler()), (\"model\", SVC(random_state=42))])\n","}\n","\n","# run cross validation\n","print(f\"{'Model':<25} {'CV Mean':>10} {'CV Std':>10}\")\n","print(\"-\" * 50)\n","\n","for name, model in models.items():\n","    scores = cross_val_score(model, X_cv, y_cv, cv=5, scoring=\"recall\")\n","    print(f\"{name:<25} {scores.mean()*100:>9.2f}% {scores.std()*100:>9.2f}%\")"],"metadata":{"id":"VdbhCuwgKlTG","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1780241359829,"user_tz":-300,"elapsed":4542,"user":{"displayName":"Salman 95","userId":"02349542020616087787"}},"outputId":"8321ee11-e371-45f7-ebf7-dd4a69114b49"},"execution_count":73,"outputs":[{"output_type":"stream","name":"stdout","text":["Model                        CV Mean     CV Std\n","--------------------------------------------------\n","Logistic Regression           87.86%      6.03%\n","Decision Tree                 82.99%      7.27%\n","Random Forest                 88.45%      4.81%\n","KNN                           85.98%      6.22%\n","SVM                           86.57%      3.69%\n"]}]},{"cell_type":"markdown","source":["# Final conclusion For Model Selection"],"metadata":{"id":"2xNNJ-6aEwGB"}},{"cell_type":"code","source":["# Final Model Selection based on Cross Validation Results:\n","# Random Forest selected as final model for following reasons:\n","# 1. Highest CV Mean Recall (88.45%) — best at catching actual disease cases\n","# 2. Low CV Std (4.81%) — consistent and stable across all data splits\n","# 3. SVM has lower std (3.69%) but lower CV Mean (86.57%) — less accurate overall\n","# 4. Decision Tree weakest — highest std (7.27%) means unstable and unreliable\n","# Conclusion: Random Forest gives best balance of accuracy and consistency"],"metadata":{"id":"XRzaz_GrE7IK","executionInfo":{"status":"ok","timestamp":1780241359834,"user_tz":-300,"elapsed":2,"user":{"displayName":"Salman 95","userId":"02349542020616087787"}}},"execution_count":74,"outputs":[]},{"cell_type":"markdown","source":["# Feature Importance"],"metadata":{"id":"3-GGWLfO5vt1"}},{"cell_type":"code","source":["import pandas as pd\n","import matplotlib.pyplot as plt\n","import seaborn as sns\n","\n","# get feature importance from trained random forest\n","feature_importance = pd.DataFrame({\n","    \"Feature\"   : X.columns,\n","    \"Importance\": rf_model.feature_importances_\n","})\n","\n","# sort by importance\n","feature_importance = feature_importance.sort_values(\"Importance\", ascending=False)\n","\n","print(feature_importance)"],"metadata":{"id":"P1dmYUmeMKww","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1780244684038,"user_tz":-300,"elapsed":23,"user":{"displayName":"Salman 95","userId":"02349542020616087787"}},"outputId":"0ef9fe7e-d6de-45e5-a2c3-a58805676bf9"},"execution_count":91,"outputs":[{"output_type":"stream","name":"stdout","text":["     Feature  Importance\n","2         cp    0.160628\n","7    thalach    0.133451\n","9    oldpeak    0.114651\n","12      thal    0.113458\n","11        ca    0.101192\n","0        age    0.076481\n","3   trestbps    0.061551\n","10     slope    0.056544\n","8      exang    0.056273\n","4       chol    0.051482\n","1        sex    0.045012\n","6    restecg    0.024206\n","5        fbs    0.005071\n"]}]},{"cell_type":"code","source":["plt.figure(figsize=(10, 6))\n","sns.barplot(x=\"Importance\", y=\"Feature\", data=feature_importance, palette=\"coolwarm\")\n","plt.title(\"Random Forest - Feature Importance\")\n","plt.xlabel(\"Importance Score\")\n","plt.ylabel(\"Features\")\n","plt.tight_layout()\n","plt.show()"],"metadata":{"id":"MHUGC9lQ6Awg","colab":{"base_uri":"https://localhost:8080/","height":694},"executionInfo":{"status":"ok","timestamp":1780244688186,"user_tz":-300,"elapsed":349,"user":{"displayName":"Salman 95","userId":"02349542020616087787"}},"outputId":"aa41a3e2-1409-4115-d7a3-9e0c6f4bf8ce"},"execution_count":92,"outputs":[{"output_type":"stream","name":"stderr","text":["/tmp/ipykernel_3026/838099601.py:2: FutureWarning: \n","\n","Passing `palette` without assigning `hue` is deprecated and will be removed in v0.14.0. Assign the `y` variable to `hue` and set `legend=False` for the same effect.\n","\n","  sns.barplot(x=\"Importance\", y=\"Feature\", data=feature_importance, palette=\"coolwarm\")\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["import joblib\n","import os\n","\n","# create models folder\n","os.makedirs(\"models\", exist_ok=True)\n","\n","# save random forest model\n","joblib.dump(rf_model, \"models/heart_disease_model.pkl\")\n","\n","# save scaler\n","joblib.dump(scaler, \"models/scaler.pkl\")\n","\n","print(\"Model Saved! ✅\")\n","print(\"Scaler Saved! ✅\")"],"metadata":{"id":"4Ik83XST9Cdn","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1780244694063,"user_tz":-300,"elapsed":224,"user":{"displayName":"Salman 95","userId":"02349542020616087787"}},"outputId":"f2f6cea8-1d6a-4aa1-b215-9f248ab17a54"},"execution_count":93,"outputs":[{"output_type":"stream","name":"stdout","text":["Model Saved! ✅\n","Scaler Saved! ✅\n"]}]},{"cell_type":"code","source":["from google.colab import drive\n","import joblib\n","import os\n","\n","# mount google drive\n","drive.mount('/content/drive')\n","\n","# your project path\n","project_path = \"/content/drive/MyDrive/Semesters_6/Data_Mining/Project\"\n","\n","# save model\n","joblib.dump(rf_model, f\"{project_path}/heart_disease_model.pkl\")\n","\n","# save scaler\n","joblib.dump(scaler, f\"{project_path}/scaler.pkl\")\n","\n","print(\"Model Saved! ✅\")\n","print(\"Scaler Saved! ✅\")"],"metadata":{"id":"sYinbMKnNQZe","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1780244700644,"user_tz":-300,"elapsed":4289,"user":{"displayName":"Salman 95","userId":"02349542020616087787"}},"outputId":"d892b06b-357c-4a63-9a75-b163bb8ae793"},"execution_count":94,"outputs":[{"output_type":"stream","name":"stdout","text":["Drive already mounted at /content/drive; to attempt to forcibly remount, call drive.mount(\"/content/drive\", force_remount=True).\n","Model Saved! ✅\n","Scaler Saved! ✅\n"]}]},{"cell_type":"code","source":["print(os.listdir(project_path))"],"metadata":{"id":"NvOVeBhmNSpS","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1780244705019,"user_tz":-300,"elapsed":7,"user":{"displayName":"Salman 95","userId":"02349542020616087787"}},"outputId":"a71598f7-944f-45c5-b626-c86932e46235"},"execution_count":95,"outputs":[{"output_type":"stream","name":"stdout","text":["['Heart_Disease', 'Help For Project CardioPredict.pdf', 'First Improvement.txt', 'first_cardiopredict_final_gui.html', 'second_cardiopredict_v2_final.html', 'third_cardiopredict_v3_fixed.html', 'four_cardiopredict_v4.html', 'fifth_cardiopredict_v5_final.html', 'sixth_cardiopredict_v6.html', 'seventh_cardiopredict_v7.html', 'eighth_cardiopredict_v8.html', 'ninth_cardiopredict_v9.html', 'Data_Mining.ipynb .ipynb', 'scaler.pkl', 'heart_disease_model.pkl']\n"]}]},{"cell_type":"code","source":[],"metadata":{"id":"X7rJ0HhPNbjD","executionInfo":{"status":"aborted","timestamp":1780241360165,"user_tz":-300,"elapsed":23379,"user":{"displayName":"Salman 95","userId":"02349542020616087787"}}},"execution_count":null,"outputs":[]}]}